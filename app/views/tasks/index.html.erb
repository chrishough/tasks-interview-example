<h1 class="text-2xl font-bold mb-4">Tasks</h1>

<table class="w-full text-left">
  <thead>
    <tr class="border-b">
      <th class="py-2 pr-8"><%= task_sort_link(label: "Title", column: "title") %></th>
      <th class="py-2 pr-8">Status</th>
      <th class="py-2 pr-8"><%= task_sort_link(label: "Due date", column: "due_date") %></th>
      <th class="py-2 pr-8">Description</th>
      <th class="py-2"></th>
    </tr>
  </thead>
  <tbody>
    <%- @tasks.each do |task| %>
      <tr class="border-b">
        <td class="py-2 pr-8 font-semibold"><%= task.title %></td>
        <td class="py-2 pr-8"><%= task.complete? ? "Complete" : "Incomplete" %></td>
        <td class="py-2 pr-8"><%= task.due_date && "Due #{task.due_date.strftime("%b %-d, %Y")}" %></td>
        <td class="py-2 pr-8 italic"><%= task.description&.truncate(50) %></td>
        <td class="py-2">
          <div class="flex gap-x-2">
            <%= button_to task.complete? ? "Mark incomplete" : "Mark complete",
              task_path(task),
              method: :patch,
              params: { task: { complete: !task.complete? } },
              class: "cursor-pointer underline" %>
            <%= link_to "Edit", edit_task_path(task) %>
            <%= link_to "Delete", task_path(task), data: { turbo_method: "delete" } %>
          </div>
        </td>
      </tr>
    <%- end %>
  </tbody>
</table>

<hr class="my-8" />

<%= render partial: "form", locals: { task: @task } %>
