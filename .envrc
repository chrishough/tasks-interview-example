# DO NOT CHECK IN THIS FILE!

export DB_VERSION=1
export PORT=300${DB_VERSION}
export PGGSSENCMODE=disable
export POSTGRES_PORT=5433

# Disables GSS/Kerberos authentication check in the pg gem.
# Required on macOS Apple Silicon to prevent a segfault when forking workers
# (Solid Queue's Puma plugin, pgsync's parallel workers, etc.).
# See: https://github.com/ged/ruby-pg/issues/538
export PGGSSENCMODE=disable

# Disables macOS unified logging activity tracing inside the process.
# Required on Ruby 4.0+ on Apple Silicon — the pg gem's libpq calls into
# os_log, which collides with Ruby 4.0's stricter fork-safety enforcement
# (rb_thread_prevent_fork) and segfaults pgsync. Safe to leave on; only
# affects in-process os_log activity streams, not application logging.
export OS_ACTIVITY_MODE=disable
